# Frontend Environment Variables

# ==============================================
# API CONFIGURATION
# ==============================================

# API Base URL for backend communication
VITE_API_BASE_URL=/api

# Full API URL (used for production builds and SSE connections)
# Leave empty for relative URLs, or set for absolute URLs
VITE_API_URL=

# ==============================================
# FEATURE FLAGS
# ==============================================

# Set to 'false' to hide the donation button (defaults to true if not set)
VITE_SHOW_DONATION_BUTTON=true

# GrowthBook feature flags / experiments
# Leave disabled by default so the public repo does not require your private GrowthBook instance.
VITE_GROWTHBOOK_ENABLED=false
VITE_GROWTHBOOK_API_HOST=https://growthbook-api.blipyy.io
VITE_GROWTHBOOK_CLIENT_KEY=

# Optional: enable GrowthBook debug/dev mode in local development
VITE_GROWTHBOOK_DEV_MODE=false

# ==============================================
# ANALYTICS CONFIGURATION (OPTIONAL)
# ==============================================

# PostHog Analytics Configuration
# Set VITE_POSTHOG_ENABLED to 'true' to enable PostHog tracking
VITE_POSTHOG_ENABLED=false

# Your PostHog project API key (get this from your PostHog project settings)
VITE_POSTHOG_KEY=

# PostHog API host (default: https://us.i.posthog.com for US cloud)
# For EU cloud use: https://eu.i.posthog.com
# For self-hosted use your own domain
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ==============================================
# DEVELOPMENT CONFIGURATION
# ==============================================

# Development mode settings
# These are typically auto-detected but can be overridden

# Set to 'development' for local development
NODE_ENV=production
